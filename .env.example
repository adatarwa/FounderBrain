# FounderBrain config
# Copy to .env and fill in your values

# Required — get free at console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Optional — for Notion export
# 1. Go to notion.so/my-integrations → create integration → copy token
# 2. Share your target database with the integration
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Optional — for Google Docs export
# See output/exporters.py for setup instructions
